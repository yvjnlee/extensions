{
  "manifest_version": 3,
  "name": "minimal-x",
  "version": "0.2.0",
  "description": "Reduce noise on X by showing only built-in Articles or strict high-signal posts.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "action": {
    "default_title": "minimal-x",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "src/shared/storage.js",
        "src/content/detector.js",
        "src/content/filter.js",
        "src/content/page-controls.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
